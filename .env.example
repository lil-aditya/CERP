# ==================================
# CERP Production Environment Config
# ==================================
# Copy this file to .env and fill in your values

# =============
# Backend Config
# =============
NODE_ENV=production
PORT=5000

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Super Admin Credentials
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourSecurePassword123!

# =============
# Google OAuth (Gmail Integration)
# =============
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/gmail/callback

# =============
# Local AI (Privacy-Preserving Digest + Semantic Search)
# =============
# Install/run Ollama on the same machine or campus server for local-only AI.
# The app falls back to deterministic local logic when Ollama is unavailable.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMAIL_DIGEST_MODE=auto
EMAIL_DIGEST_MAX_LLM_PER_SYNC=10
SEMANTIC_EMBEDDING_PROVIDER=auto

# =============
# Frontend Config
# =============
VITE_API_URL=https://yourdomain.com

# =============
# URLs (for OAuth redirects)
# =============
FRONTEND_URL=https://yourdomain.com
